# Public connection values for the web application.
# Copy this file to .env.local and insert the real values only on your computer
# or in the private environment settings of the hosting provider.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Never expose SUPABASE_SERVICE_ROLE_KEY in browser code.
# SUPABASE_SERVICE_ROLE_KEY is intentionally not used by the public website.
